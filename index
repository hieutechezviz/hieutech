    function calculate() {
      const cameras = Math.max(1, parseInt(document.getElementById('calc-cameras').value) || 1);
      const rate = resolutionRates[resolution];
      const resultEl = document.getElementById('calc-result');

      if (calcMode === 'storage') {
        const days = Math.max(1, parseInt(document.getElementById('calc-days').value) || 1);
        const total = rate * cameras * days;
        const display = total >= 1000 ? (total / 1024).toFixed(2) : Math.ceil(total);
        const unit = total >= 1000 ? 'TB' : 'GB';
        const suggest = total <= 32 ? '32 GB' : total <= 64 ? '64 GB' : total <= 128 ? '128 GB' : total <= 256 ? '256 GB' : total <= 512 ? '512 GB' : `${Math.ceil(total / 1024)} TB`;
        resultEl.innerHTML = `
          <div class="text-5xl font-bold mb-2">${display}<span class="text-2xl ml-2 font-medium text-blue-200">${unit}</span></div>
          <p class="text-blue-100 text-sm mt-4 leading-relaxed">Để lưu trữ cho <strong class="text-white">${cameras} camera</strong> độ phân giải <strong class="text-white">${resolution}</strong> trong vòng <strong class="text-white">${days} ngày</strong>.</p>
          <div class="mt-8 p-4 bg-white/10 rounded-xl border border-white/20"><p class="text-sm">Gợi ý thẻ nhớ/Ổ cứng mua:</p><p class="font-bold text-lg mt-1">${suggest}</p></div>`;
      } else {
        const capacity = Math.max(1, parseInt(document.getElementById('calc-capacity').value) || 1);
        const possibleDays = Math.floor(capacity / (rate * cameras));
        resultEl.innerHTML = `
          <div class="text-5xl font-bold mb-2">${possibleDays}<span class="text-2xl ml-2 font-medium text-blue-200">Ngày</span></div>
          <p class="text-blue-100 text-sm mt-4 leading-relaxed">Với dung lượng <strong class="text-white">${capacity >= 1024 ? (capacity/1024)+'TB' : capacity+'GB'}</strong>, hệ thống <strong class="text-white">${cameras} camera</strong> độ phân giải <strong class="text-white">${resolution}</strong> có thể lưu trữ tối đa.</p>`;
      }
    }

    function initCalculator() {
      const resBtns = document.getElementById('resolution-btns');
      resBtns.innerHTML = Object.keys(resolutionRates).map(res => `<button data-res="${res}" onclick="setResolution('${res}')" class="py-2 text-sm font-medium rounded-lg border transition-all ${res === resolution ? 'border-blue-500 bg-blue-50 text-blue-700' : 'border-gray-200 bg-white text-gray-600 hover:border-blue-300'}">${res}</button>`).join('');
      
      const presets = document.getElementById('capacity-presets');
      presets.innerHTML = [32,64,128,256,512,1024,2048,4096].map(c => `<button onclick="document.getElementById('calc-capacity').value=${c};calculate()" class="px-3 py-1 text-xs border border-gray-200 rounded-full hover:bg-gray-50 text-gray-600">${c>=1024?(c/1024)+'TB':c+'GB'}</button>`).join('');
      
      document.getElementById('rate-info').innerHTML = `<i data-lucide="info" class="w-3.5 h-3.5"></i> Tốc độ tiêu hao ước tính: ~${resolutionRates[resolution]} GB/Ngày (Chuẩn H.265)`;
      calculate();
    }

    // LOCK EVALUATOR
    function initLockTool() {
      const select = document.getElementById('lock-select');
      select.innerHTML = '<option value="" disabled selected>-- Chọn dòng khóa --</option>' + 
        LOCK_MODELS.map(l => `<option value="${l.id}">${l.name}</option>`).join('');
    }

    function renderLockStep() {
      for(let i=1; i<=6; i++) {
        const el = document.getElementById('lock-step-' + i);
        if(el) el.classList.toggle('hidden', lockState.step !== i);
      }
      document.getElementById('lock-progress').innerText = `Bước ${lockState.step}/6`;
      lucide.createIcons();
    }

    function onLockSelect(e) {
      const val = e.target.value;
      lockState.selectedLock = val;
      if (val) {
        lockState.lockType = LOCK_MODELS.find(l => l.id === val).type;
        lockState.step = 2;
        document.getElementById('lock-type-label').innerText = lockState.lockType === 'wood' ? 'KHÓA CỬA GỖ' : 'KHÓA CỬA NHÔM';
        renderLockStep();
      }
    }

    function confirmLockType() {
      lockState.step = 3;
      renderLockStep();
    }

    function validateLockDim() {
      const t = document.getElementById('lock-thickness').value;
      const d = document.getElementById('lock-depth').value;
      document.getElementById('btn-lock-dim').disabled = (!t || !d);
    }

    function checkLockDimensions() {
      const t = parseFloat(document.getElementById('lock-thickness').value.replace(',', '.'));
      const d = parseFloat(document.getElementById('lock-depth').value.replace(',', '.'));
      
      if (isNaN(t) || isNaN(d)) return;

      if (lockState.lockType === 'wood') {
        if (t < 3.5 || d < 9.9) {
          lockState.result = 'fail';
          lockState.step = 6;
        } else {
          lockState.step = 4;
        }
      } else if (lockState.lockType === 'alum') {
        if (t < 3.0 || d < 7.0) {
          lockState.result = 'fail';
          lockState.step = 6;
        } else {
          lockState.step = 4;
        }
      }
      renderLockResult();
      renderLockStep();
    }

    function selectDoorStatus(status) {
      lockState.doorStatus = status;
      if (status === 'new') {
        lockState.result = 'success';
        lockState.step = 6;
      } else {
        lockState.step = 5;
      }
      renderLockResult();
      renderLockStep();
    }

    function validateLockDist() {
      const hd = document.getElementById('lock-handle-distance').value;
      document.getElementById('btn-lock-dist').disabled = !hd;
    }

    function checkLockHandleDistance() {
      const hd = parseFloat(document.getElementById('lock-handle-distance').value.replace(',', '.'));
      if (isNaN(hd)) return;

      if (lockState.lockType === 'wood') {
        if (hd > 5.7 && hd < 6.3) {
          lockState.result = 'success';
        } else {
          lockState.result = 'fail';
        }
      } else if (lockState.lockType === 'alum') {
        if (hd > 3.3 && hd < 3.7) {
          lockState.result = 'success';
        } else {
          lockState.result = 'fail';
        }
      }
      lockState.step = 6;
      renderLockResult();
      renderLockStep();
    }

    function renderLockResult() {
      const successUI = document.getElementById('lock-result-success');
      const failUI = document.getElementById('lock-result-fail');
      if (lockState.result === 'success') {
        successUI.classList.remove('hidden');
        failUI.classList.add('hidden');
      } else {
        successUI.classList.add('hidden');
        failUI.classList.remove('hidden');
      }
    }

    function resetLockTool() {
      lockState = { step: 1, selectedLock: '', lockType: null, doorStatus: '', result: null };
      document.getElementById('lock-select').value = '';
      document.getElementById('lock-thickness').value = '';
      document.getElementById('lock-depth').value = '';
      document.getElementById('lock-handle-distance').value = '';
      document.getElementById('btn-lock-dim').disabled = true;
      document.getElementById('btn-lock-dist').disabled = true;
      renderLockStep();
    }

    //    // INSTALLER SEARCH
    function initInstallerTool() {
      const select = document.getElementById('installer-select');
      select.innerHTML = '<option value="" disabled selected>-- Chọn Tỉnh / Thành phố --</option>' + 
        PROVINCES.map(p => `<option value="${p}">${p}</option>`).join('');
    }

    function checkInstaller() {
      const val = document.getElementById('installer-select').value;
      const successUI = document.getElementById('installer-result-success');
      const failUI = document.getElementById('installer-result-fail');
      
      if (!val) return;

      if (SUPPORTED_PROVINCES.includes(val)) {
        successUI.classList.remove('hidden');
        failUI.classList.add('hidden');
      } else {
        successUI.classList.add('hidden');
        failUI.classList.remove('hidden');
      }
      lucide.createIcons();
    }

    // INIT APP
    filterFaqs();
    filterProducts();
    initCalculator();
    initLockTool();
    initInstallerTool();
    lucide.createIcons();
  </script>
